FROM python:3.12-slim

RUN apt-get update \
    && apt-get install -y --no-install-recommends ffmpeg \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

COPY . .

RUN groupadd -r tts && useradd -r -g tts tts && chown -R tts:tts /app
USER tts

EXPOSE 8080
CMD ["python", "-m", "uvicorn", "tts_worker:app", "--host", "0.0.0.0", "--port", "8080"]
