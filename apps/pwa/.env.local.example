# Copy this to .env.local and fill in your Firebase project values
# Get these from Firebase Console → Project settings → Your apps → Config

NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=almeisan-adk-sandbox
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# GCP project for API calls
NEXT_PUBLIC_GCP_PROJECT=almeisan-adk-sandbox
NEXT_PUBLIC_GCP_REGION=asia-northeast1

# Agents service URL (Cloud Run)
# Local dev: http://localhost:8080
# Production: https://sessioncast-agents-XXXX-an.a.run.app
NEXT_PUBLIC_AGENTS_URL=
