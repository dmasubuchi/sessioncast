{
  "hosting": {
    "public": "out",
    "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
    "cleanUrls": true,
    "trailingSlash": false,
    "headers": [
      {
        "source": "**/*.@(js|css|woff2)",
        "headers": [{"key": "Cache-Control", "value": "max-age=31536000,immutable"}]
      },
      {
        "source": "**",
        "headers": [{"key": "X-Frame-Options", "value": "DENY"},
                    {"key": "X-Content-Type-Options", "value": "nosniff"}]
      }
    ]
  }
}
